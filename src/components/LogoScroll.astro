---
const base = import.meta.env.BASE_URL;
const logos = [
  { name: "The Great Fire Company", url: `${base}images/logos/the-great-fire-company.png` },
  { name: "Calming Co", url: `${base}images/logos/calming-co.png` },
  { name: "Indoor Golf Outlet", url: `${base}images/logos/indoor-golf-outlet.png` },
  { name: "Krush Kandy", url: `${base}images/logos/krush-kandy.png` },
  { name: "Lyric Cycles", url: `${base}images/logos/lyric-cycles.png` },
  { name: "Premium Saunas", url: `${base}images/logos/premium-saunas.png` },
  { name: "Off-Grid Source", url: `${base}images/logos/off-grid-source.png` },
  { name: "Garmin", url: `${base}images/logos/garmin.png` },
  { name: "Royal Fire Pits", url: `${base}images/logos/royal-fire-pits.png` },
  { name: "Sauna Heaters", url: `${base}images/logos/sauna-heaters.png` },
  { name: "Sleep by Santi", url: `${base}images/logos/sleep-by-santi.png` },
  { name: "TAVO", url: `${base}images/logos/tavo.png` },
  { name: "VitalTrack", url: `${base}images/logos/vitaltrack.png` },
  { name: "Yerba Magic", url: `${base}images/logos/yerba-magic.png` },
  { name: "STRIDE", url: `${base}images/logos/stride.png` },
  { name: "Daily Dose", url: `${base}images/logos/daily-dose.png` },
  { name: "Fernes", url: `${base}images/logos/fernes.png` },
  { name: "MATTE Collection", url: `${base}images/logos/matte-collection.png` },
  { name: "Lakewood University", url: `${base}images/logos/lakewood-university.png` },
  { name: "New Client", url: `${base}images/logos/new-client.png` },
];

const midPoint = Math.ceil(logos.length / 2);
const topRow = logos.slice(0, midPoint);
const bottomRow = logos.slice(midPoint);
---

<section
  class="py-2 md:py-4 px-4 overflow-hidden"
  style="background: linear-gradient(to bottom, rgba(90, 138, 199, 0.12) 0%, rgba(90, 138, 199, 0.06) 60%, white 100%);"
>
  <div class="max-w-7xl mx-auto">
    <p class="text-center text-slate-600 text-sm mb-8 font-medium">
      TRUSTED BY LEADING BRANDS
    </p>

    <div class="space-y-6">
      <!-- Top row (scroll left) -->
      <div class="relative">
        <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-[#fafafa] to-transparent z-10"></div>
        <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-[#fafafa] to-transparent z-10"></div>
        <div class="logo-scroll-left flex gap-12 items-center">
          {[...topRow, ...topRow].map((logo) => (
            <div class="flex-shrink-0 w-40 h-16 flex items-center justify-center">
              <img
                src={logo.url}
                alt={logo.name}
                class="max-w-full max-h-full object-contain opacity-60 hover:opacity-90 transition-opacity"
                style="filter: grayscale(100%);"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Bottom row (scroll right) -->
      <div class="relative">
        <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-[#fafafa] to-transparent z-10"></div>
        <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-[#fafafa] to-transparent z-10"></div>
        <div class="logo-scroll-right flex gap-12 items-center">
          {[...bottomRow, ...bottomRow].map((logo) => (
            <div class="flex-shrink-0 w-40 h-16 flex items-center justify-center">
              <img
                src={logo.url}
                alt={logo.name}
                class="max-w-full max-h-full object-contain opacity-60 hover:opacity-90 transition-opacity"
                style="filter: grayscale(100%);"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
