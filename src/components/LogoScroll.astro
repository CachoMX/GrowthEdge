  { name: "Sleep by Santi", url: "https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/69896edb8c6aa7e8462b7a54/efc02a056_SleepBySanti_White_250x_2x.png" },
