// Server-side title highlighting: wrap money pattern matches in <span class="text-highlight-card">
function highlightTitle(titleRaw: string, caseNumber: number): string {
  const text = titleRaw.replace(/\n/g, ' ');

  const patterns: RegExp[] = [
    /\$158K\s+Revenue\s+in\s+4\s+Months/g,
    /\$208K\s*→\s*\$427K/g,
    /\$163K\s+Spend\s*→\s*\$587K\s+Revenue/g,
    /\$445K\s+→/g,
    /\$2\.93M\s+Over\s+7\s+Months/g,
    /\$39K\s+to\s+\$1\.3M\s+Monthly/g,
    /\$1\.86M\s+→\s+\$27\.2M/g,
    /\$101K\s+→\s+\$386K/g,
    /\$145K\s+→\s+\$1\.2M/g,
    /Generated\s+\$1\.34M\s+Revenue/g,
    /\$1\.24M\s+Total\s+Revenue\s+\(\+106%\)/g,
    /\$198K\s+→\s+\$1\.74M/g,
    /\$367K\s+→\s+\$800K/g,
    /\$5\.06M\s+Revenue/g,
    /\$524K\s+Spend\s+→/g,
    /\$187K\s+→\s+\$1\.67M\s+\(8\.9x\s+ROAS\)/g,
    /\$2\.73M\s+in\s+a\s+Single\s+Month/g,
    /\$[\d,.]+[KMB]?\s*→\s*\$[\d,.]+[KMB]?\s*\|\s*[\d,.]+x\s+ROAS/g,
    /\$[\d,.]+[KMB]?\s+Spend\s*→\s*\$[\d,.]+[KMB]?\s+Revenue\s*\|\s*[\d,.]+x\s+ROAS/g,
    /\$[\d,.]+[KMB]?\s+Spend\s*→\s*\$[\d,.]+[KMB]?\s+Revenue\s*\([\d,.]+x\s+ROAS\)/g,
    /\$[\d,.]+[KMB]?\s+Revenue\s+\([\d,.]+x\s+ROAS\)/g,
    /\$[\d,.]+[KMB]?\s*→\s*\$[\d,.]+[KMB]?\s+Monthly/g,
    /→\s*\$[\d,.]+[KMB]?\s+Revenue(?:\s+\||$)/g,
    /→\s*\$[\d,.]+[KMB]?\s*\([\d,.]+x\s+ROAS\)/g,
    /\$[\d,.]+[KMB]?\s+in\s+a\s+Single\s+Month/g,
    /\$[\d,.]+[KMB]?\s+\(\+[\d,]+%\)/g,
  ];

  if (caseNumber !== 13) {
    patterns.push(
      /→\s*\$[\d,.]+[KMB]?\s+Revenue\s+in\s+\d+\s+Months\s+From\s+Scratch\s+\([\d,.]+x\s+ROAS\)/g,
      /\$[\d,.]+[KMB]?\s+Revenue\s+in\s+\d+\s+Months\s+From\s+Scratch\s+\([\d,.]+x\s+ROAS\)/g,
    );
  }

  let bestMatch: RegExpExecArray | null = null;

  for (const pattern of patterns) {
    pattern.lastIndex = 0;
    const m = pattern.exec(text);
    if (m) {
      if (!bestMatch || m.index < bestMatch.index) {
        bestMatch = m;
      }
    }
  }

  if (!bestMatch) {
    // Fallback: highlight individual money values
    return text.replace(/(\$[\d,.]+[KMB]?)/g, '<span class="text-highlight-card">$1</span>');
  }

  const matchStr = bestMatch[0];
  let before = text.substring(0, bestMatch.index);
  let highlight = matchStr;
  let after = text.substring(bestMatch.index + matchStr.length);

  // If match ends with ' in', move that outside the highlight
  if (highlight.endsWith(' in')) {
    highlight = highlight.slice(0, -3);
    after = ' in' + after;
  }

  return `${before}<span class="text-highlight-card">${highlight}</span>${after}`;
}

// CTA button SVG icon (mouse pointer click)
const ctaIconSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="m9 9 5 12 1.774-5.226L21 14 9 9z" /><path d="m16.071 16.071 4.243 4.243" /><path d="m7.188 2.239.777 2.897" /><path d="M5.136 7.965l-2.898-.777" /><path d="M14.869 5.136l2.898-.777" /><path d="m2.239 14.869.777-2.898" /></svg>`;

// Arrow icon for before/after
