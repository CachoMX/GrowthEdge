---
const slackScreenshots = Array.from({ length: 34 }, (_, i) => `/home/images/slack/${i + 1}.png`);
---

<section class="py-20 px-4" style="background-color: #f5f7fb;">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-2xl md:text-4xl lg:text-5xl font-bold text-slate-900 px-4 md:px-0">
        <span class="slack-straight-highlight">Straight</span> From the <span class="text-highlight-grizzle-wide">Client Chat</span>.
      </h2>
    </div>
    <div class="columns-2 sm:columns-3 md:columns-4 lg:columns-5 gap-3 space-y-3">
      {slackScreenshots.map((screenshot) => (
        <div class="break-inside-avoid rounded-lg overflow-hidden border border-slate-200 shadow-sm hover:shadow-md transition-all duration-300">
          <img
            src={screenshot}
            alt="Client Slack message"
            class="w-full h-auto cursor-pointer"
            data-lightbox={screenshot}
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox Modal (hidden by default) -->
<div
  id="lightbox-modal"
  class="fixed inset-0 bg-black bg-opacity-75 items-center justify-center z-50 p-4 hidden"
>
  <div class="relative max-w-4xl max-h-[90vh] flex items-center justify-center">
    <img
      id="lightbox-img"
      src=""
      alt="Enlarged Slack message"
      class="max-w-full max-h-[90vh] object-contain rounded-lg"
    />
    <button
      id="lightbox-close"
      class="absolute top-4 right-4 bg-white rounded-full p-2 hover:bg-gray-200 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-black">
        <path d="M18 6 6 18" />
        <path d="M6 6 18 18" />
      </svg>
    </button>
  </div>
</div>
